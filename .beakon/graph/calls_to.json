  "func(name string) {\n\t\t\tdefer wg.Done()\n\t\t\tvar fi pkg.FileIndex\n\t\t\tif err := readJSON(filepath.Join(dir, name), \u0026fi); err == nil {\n\t\t\t\tmu.Lock()\n\t\t\t\tall = append(all, fi)\n\t\t\t\tmu.Unlock()\n\t\t\t}\n\t\t}": [
